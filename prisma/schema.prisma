// E-ARI — Enterprise AI Readiness Assessment Platform
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  passwordHash     String?
  organization     String?
  sector           String?  // Industry sector for benchmarking
  orgSize          String?  // "1-50", "51-200", "201-1000", "1001-5000", "5000+"
  tier             String   @default("free") // "free" | "professional" | "enterprise"
  role             String   @default("user") // "user" | "admin"
  image            String?
  stripeCustomerId String?  // Stripe customer ID for billing portal
  emailVerified    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  assessments       Assessment[]
  accounts          Account[]
  sessions          Session[]
  pipelineRuns      PipelineRun[]
  pulseRuns         PulseRun[]
  integrations      Integration[]
  notifications     Notification[]
  benchmarkConsents BenchmarkConsent[]
  refundRequests    RefundRequest[]
  aiSystems         AISystem[]
  evidenceItems     Evidence[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Assessment {
  id                String   @id @default(cuid())
  userId            String
  sector            String   @default("general") // Industry sector: "healthcare" | "finance" | "manufacturing" | "retail" | "government" | "technology" | "energy" | "education" | "general"
  status            String   @default("draft") // "draft" | "completed" | "archived"
  scoringVersion    String   @default("1.0.0")
  methodologyVersion String  @default("1.0.0")
  overallScore      Float?
  maturityBand      String?  // "laggard" | "follower" | "chaser" | "pacesetter"
  pillarScores      String?  // JSON string of pillar scores
  aiInsights        String?  // JSON string of AI-generated insights
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  previousAssessmentId  String?
  benchmarkConsented    Boolean   @default(false)
  isPulse              Boolean   @default(false)
  pulseMonth           String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses     Response[]
  pipelineRuns  PipelineRun[]
  aiSystems     AISystem[]
}

model Response {
  id           String   @id @default(cuid())
  assessmentId String
  pillarId     String   // e.g. "strategy", "data", etc.
  questionId   String   // e.g. "strategy_1"
  answer       Int      // Likert 1-5 or numeric value
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Platform Settings ────────────────────────────────────────────────────────

model PlatformSetting {
  key       String   @id
  value     String   // JSON-encoded value
  updatedAt DateTime @updatedAt
}

// ─── Orchestrator Pipeline Models ────────────────────────────────────────────

model PipelineRun {
  id            String   @id @default(cuid())
  assessmentId  String
  userId        String
  status        String   @default("pending") // "pending" | "running" | "completed" | "failed" | "partial"
  triggeredBy   String   @default("auto")    // "auto" (on submit) | "manual" | "retry"
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assessment Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  stages     PipelineStage[]

  @@index([assessmentId])
  @@index([userId])
}

model PipelineStage {
  id            String   @id @default(cuid())
  pipelineRunId String
  agent         String   // "scoring" | "insight" | "discovery" | "report" | "assistant" | "literacy"
  status        String   @default("pending") // "pending" | "running" | "completed" | "failed" | "skipped"
  input         String?  // JSON string of agent input context
  output        String?  // JSON string of agent output/result
  error         String?  // Error message if failed
  durationMs    Int?     // Execution time in milliseconds
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  pipelineRun PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)

  @@index([pipelineRunId])
  @@index([agent])
}

// ─── Benchmark Data (Anonymous Aggregation) ──────────────────────────────────

model BenchmarkSnapshot {
  id             String   @id @default(cuid())
  sector         String   // "healthcare" | "finance" | etc.
  pillarId       String   // "strategy" | "data" | etc.
  avgScore       Float    // Average normalized score for this sector+pillar
  medianScore    Float
  p25Score       Float    // 25th percentile
  p75Score       Float    // 75th percentile
  p90Score       Float    // 90th percentile
  sampleSize     Int      // Number of contributing organizations
  scoringVersion String   @default("5.2")
  computedAt     DateTime @default(now())

  @@index([sector, pillarId])
  @@index([computedAt])
}

model BenchmarkConsent {
  id           String   @id @default(cuid())
  assessmentId String   @unique
  userId       String
  consented    Boolean  @default(false)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── AI Pulse (Monthly Continuous Monitoring) ─────────────────────────────────

model PulseRun {
  id           String   @id @default(cuid())
  userId       String
  assessmentId String   // The latest assessment this pulse is based on
  overallScore Float
  pillarScores String  // JSON string of pillar scores
  scoreChanges String  // JSON: { pillarId: { previous: number, current: number, delta: number } }
  topRisks     String  // JSON array of top 3 risk descriptions
  topQuickWins String  // JSON array of top 3 quick win descriptions
  month        String  // "2026-04" format
  status       String   @default("completed") // "pending" | "completed" | "failed"
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([month])
}

// ─── Integration Connections ─────────────────────────────────────────────────

model Integration {
  id         String    @id @default(cuid())
  userId     String
  provider   String    // "slack" | "teams" | "jira" | "asana" | "google_workspace" | "microsoft_365"
  status     String    @default("pending") // "pending" | "active" | "disconnected" | "error"
  config     String    // JSON: provider-specific config (webhook URLs, channel IDs, etc.)
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

// ─── Notification & Digest ────────────────────────────────────────────────────

model Notification {
  id           String   @id @default(cuid())
  userId       String
  type         String   // "pulse_ready" | "quarterly_reminder" | "benchmark_update" | "weekly_digest" | "integration_alert"
  title        String
  message      String
  read         Boolean  @default(false)
  actionUrl    String?  // e.g. "/results/abc123" or "/pulse"
  assessmentId String?  // Optional link to related assessment
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─── Social Media Automation ────────────────────────────────────────────────

model SocialAccount {
  id            String    @id @default(cuid())
  provider      String    // "linkedin", "twitter", "facebook"
  accountName   String    // Display name
  accountHandle String?   // @handle
  accessToken   String?   // Encrypted OAuth token
  refreshToken  String?
  tokenExpiresAt DateTime?
  avatarUrl     String?
  isActive      Boolean   @default(true)
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SocialPost {
  id              String    @id @default(cuid())
  content         String    // Post text
  platform        String    // "linkedin", "twitter", "facebook", "all"
  mediaUrls       String?   // JSON array of image URLs
  status          String    @default("draft") // draft, scheduled, publishing, published, failed
  scheduledAt     DateTime?
  publishedAt     DateTime?
  failedReason    String?
  category        String?   // "benchmark", "compliance", "certification", "promotion", "custom"
  autoGenerated   Boolean   @default(false)
  engagementMetrics String? // JSON: { likes, shares, comments, clicks, impressions }
  sourceData      String?   // JSON: reference data used to generate the post
  createdBy       String?   // Admin user who created it
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Contact Inbox ───────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  subject   String
  message   String
  status    String   @default("new") // "new" | "read" | "replied" | "archived"
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  replies ContactReply[]

  @@index([status])
  @@index([createdAt])
}

model ContactReply {
  id               String   @id @default(cuid())
  contactMessageId String
  subject          String
  body             String
  sentAt           DateTime @default(now())

  contactMessage ContactMessage @relation(fields: [contactMessageId], references: [id], onDelete: Cascade)

  @@index([contactMessageId])
}

// ─── Refund Requests ────────────────────────────────────────────────────────

model RefundRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  amount      Float
  reason      String    // "duplicate", "not_as_described", "accidental", "other"
  details     String?
  status      String    @default("pending") // pending, approved, rejected, refunded
  chargeId    String?
  refundId    String?
  refundedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([chargeId])
}

// ─── Compliance domain (AI Act evidence & artifacts) ───────────────────────────
// Prisma model ObligationGap avoids name clash with ComplianceGap interface in regulatory-mapping.ts

model AISystem {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentId        String?
  assessment          Assessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)

  name                String
  description         String    @db.Text
  purpose             String    @db.Text
  deployerRole        String // provider | deployer | importer | distributor
  sector              String
  populationsAffected String?   @db.Text

  riskTier            String? // prohibited | high | limited | minimal
  riskRationale       String?   @db.Text
  classifiedAt        DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  evidence            Evidence[]
  fria                FRIA?
  technicalFile       TechnicalFile?
  monitoring          MonitoringPlan?
  obligationGaps      ObligationGap[]

  @@index([userId])
  @@index([assessmentId])
}

model Evidence {
  id               String   @id @default(cuid())
  systemId         String?
  system           AISystem? @relation(fields: [systemId], references: [id], onDelete: Cascade)

  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationLevel Boolean @default(false)

  filename         String
  mimeType         String
  storageKey       String
  sizeBytes        Int
  sha256           String

  artifactType     String? // contract | policy | model_card | dpia | etc.
  classifiedAt     DateTime?

  extractedText    String?  @db.Text
  extractionStatus String   @default("pending") // pending | processing | extracted | failed
  extractionError  String?

  createdAt        DateTime @default(now())

  clauses          EvidenceClause[]

  @@index([systemId])
  @@index([userId])
  @@index([artifactType])
}

model EvidenceClause {
  id           String   @id @default(cuid())
  evidenceId   String
  evidence     Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  clauseType   String
  textExcerpt  String   @db.Text
  pageNumber   Int?
  confidence   Float

  aiActArticles String[]
  pillarIds     String[]
  frameworks    String[]

  createdAt    DateTime @default(now())

  @@index([evidenceId])
}

model FRIA {
  id               String   @id @default(cuid())
  systemId         String   @unique
  system           AISystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  status           String   @default("draft") // draft | review | finalized
  affectedGroups   Json
  rightsAtRisk     Json
  mitigations      Json
  residualRisk     String?  @db.Text
  oversightDesign  String?  @db.Text

  generatedPdfKey  String?
  finalizedAt      DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TechnicalFile {
  id                   String   @id @default(cuid())
  systemId             String   @unique
  system               AISystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  systemDescription    Json?
  designSpecs          Json?
  dataGovernance       Json?
  monitoringPlan       Json?
  riskManagement       Json?
  performanceMetrics   Json?
  instructionsForUse   Json?
  euDeclaration        Json?

  status               String   @default("draft")
  generatedPdfKey      String?
  generatedJsonKey     String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model MonitoringPlan {
  id                  String    @id @default(cuid())
  systemId            String    @unique
  system              AISystem  @relation(fields: [systemId], references: [id], onDelete: Cascade)

  conformityRoute     String // internal_control | notified_body
  nextAttestationAt   DateTime?
  triggers            Json
  incidents           Json

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model ObligationGap {
  id                       String   @id @default(cuid())
  systemId                 String
  system                   AISystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  obligationCode           String
  obligationLabel          String
  severity                 String // critical | major | minor
  recommendedArtifactType  String
  draftDocumentText        String?  @db.Text
  ownerRoleHint            String?
  status                   String   @default("open") // open | in_progress | closed | wont_do

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([systemId])
}

/// Compliance LLM observability — no PII or document content.
model ComplianceLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  operation    String?
  model        String
  durationMs   Int
  inputTokens  Int?
  outputTokens Int?
  success      Boolean
  errorClass   String?

  @@index([createdAt])
  @@index([operation])
}
