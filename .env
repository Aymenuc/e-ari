# ─── E-ARI Environment Configuration ───────────────────────────────────────────
# Copy this to .env.local for local overrides

# Database (PostgreSQL — set real value in .env.local or Vercel dashboard)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="e-ari-dev-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (uncomment + fill to enable)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# TWITTER_CLIENT_ID=""
# TWITTER_CLIENT_SECRET=""

# Stripe (uncomment + fill to enable billing)
# STRIPE_SECRET_KEY=""
# STRIPE_PUBLISHABLE_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRO_PRICE_ID=""
# STRIPE_ENTERPRISE_PRICE_ID=""
