# LOCAL ONLY — Vitest loads this when `VERCEL` is not set (see vitest.setup.ts).
# On Vercel, builds use the project’s Production/Preview env; `npm run build` runs `vitest run`
# against that database after migrations. To opt out on Vercel, set `RUN_INTEGRATION_TESTS=0`.
#
# Optional local sync from Vercel Preview:
#   npm run env:test
RUN_INTEGRATION_TESTS=1

# Transaction pooler (matches typical Prisma + Supabase setup)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session mode / direct connection (required by prisma/schema.prisma directUrl)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Optional overrides if you already use DATABASE_URL elsewhere:
# TEST_DATABASE_URL="postgresql://..."
# TEST_DIRECT_URL="postgresql://..."
