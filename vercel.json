{
  "buildCommand": "prisma generate && vitest run && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/compliance-monitoring",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/marketing-pack",
      "schedule": "0 8 * * 1"
    }
  ]
}